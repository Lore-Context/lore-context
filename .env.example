# Demo defaults are placeholders. Generate real keys via 'openssl rand -hex 32'

# Compose-only bind defaults for private deployments.
API_BIND_HOST=127.0.0.1
API_PORT=3000
DASHBOARD_BIND_HOST=127.0.0.1
DASHBOARD_PORT=3001
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_PORT=5432

# Postgres credentials used by docs/deployment/compose.private-demo.yml.
POSTGRES_DB=lore_context
POSTGRES_USER=lore
POSTGRES_PASSWORD=  # REQUIRED

# Core API runtime.
PORT=3000
LORE_STORE_PATH=./data/lore-store.json
LORE_STORE_DRIVER=
LORE_DATABASE_URL=postgres://lore:@127.0.0.1:5432/lore_context
LORE_POSTGRES_AUTO_SCHEMA=false
LORE_DEFAULT_ORGANIZATION_ID=local

# API auth. Prefer LORE_API_KEYS for shared demos or any remote/private exposure.
LORE_API_KEY=
LORE_API_KEYS=
# Example role map:
# LORE_API_KEYS='[{"key":"<YOUR_READER_KEY>","role":"reader","projectIds":["demo-private"]},{"key":"<YOUR_WRITER_KEY>","role":"writer","projectIds":["demo-private"]},{"key":"<YOUR_ADMIN_KEY>","role":"admin"}]'

# Downstream clients. For local host clients use http://127.0.0.1:3000.
# For compose-internal services the dashboard/mcp images override this to http://api:3000.
LORE_API_URL=http://127.0.0.1:3000
DASHBOARD_LORE_API_KEY=  # REQUIRED
MCP_LORE_API_KEY=
ADMIN_LORE_API_KEY=  # REQUIRED
WRITE_LORE_API_KEY=  # REQUIRED

# Dashboard HTTP Basic Auth (required in production).
DASHBOARD_BASIC_AUTH_USER=
DASHBOARD_BASIC_AUTH_PASS=

# Optional MCP transport. Empty uses the legacy local loop; "sdk" uses @modelcontextprotocol/sdk stdio.
LORE_MCP_TRANSPORT=sdk

# Optional local memory runtime. Keep this bound to localhost unless a private sidecar is required.
AGENTMEMORY_URL=http://127.0.0.1:3111
AGENTMEMORY_SECRET=
AGENTMEMORY_TIMEOUT_MS=5000
LORE_AGENTMEMORY_REQUIRED=1
LORE_AGENTMEMORY_MUTATE=1

# Rate limiting and resilience.
LORE_RATE_LIMIT_PER_IP=60
LORE_RATE_LIMIT_PER_KEY=600
LORE_REQUEST_TIMEOUT_MS=30000
LORE_MAX_JSON_BYTES=1048576

# Optional search provider adapter.
ZAPFETCH_API_URL=
ZAPFETCH_API_KEY=
